---
---

<div
  id="cookie"
  class="fixed bottom-32 md:bottom-12 left-1/2 -translate-x-1/2 bg-white/95 backdrop-blur-md border border-gray-100 rounded-[28px] shadow-[0_20px_50px_rgba(0,0,0,0.1)] p-6 md:p-8 flex flex-col items-center text-center gap-6 max-w-sm w-[calc(100%-2rem)] z-99999"
  style="animation: fadeUp .4s 1.2s ease both; opacity:0"
>
  <p class="text-sm text-gray-500 leading-relaxed font-medium">
    Utilizziamo cookie per migliorare la tua esperienza e per fini analitici. 
    Leggi la nostra <a href="/cookie" class="text-orange font-bold hover:underline">Cookie policy</a>.
  </p>
  <div class="flex flex-col w-full gap-3">
    <button
      id="accept-cookies"
      class="w-full bg-navy hover:bg-orange text-white text-[11px] font-black uppercase tracking-widest py-4 rounded-2xl transition-all shadow-lg shadow-navy/10 hover:shadow-orange/20 cursor-pointer hover:scale-[1.02] active:scale-95"
      >Accetta Tutto</button
    >
    <button
      id="accept-necessary-cookies"
      class="w-full border border-gray-100 text-gray-400 hover:text-navy hover:bg-gray-50 text-[11px] font-black uppercase tracking-widest py-4 rounded-2xl transition-all cursor-pointer hover:scale-[1.02] active:scale-95"
      >Solo necessari</button
    >
  </div>
</div>

<script is:inline>
  // Cookie Banner handling
  const cookieEl = document.getElementById("cookie");
  const acceptAllBtn = document.getElementById("accept-cookies");
  const acceptNecessaryBtn = document.getElementById("accept-necessary-cookies");

  function setConsent(status) {
    localStorage.setItem("cookie-consent", status);
    if (typeof gtag === 'function') {
      gtag('consent', 'update', {
        'ad_storage': status,
        'analytics_storage': status,
        'ad_user_data': status,
        'ad_personalization': status
      });
    }
    if (cookieEl) cookieEl.style.display = "none";
  }

  if (cookieEl) {
    if (localStorage.getItem("cookie-consent")) {
      cookieEl.style.display = "none";
    } else {
      cookieEl.style.opacity = "1";
    }

    acceptAllBtn?.addEventListener("click", () => setConsent('granted'));
    acceptNecessaryBtn?.addEventListener("click", () => setConsent('denied'));
  }
</script>


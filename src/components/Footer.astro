---
---

<footer
  class="bg-navy pt-24 pb-12 border-t border-white/5 relative overflow-hidden"
>
  <!-- Decorative Glow -->
  <div
    class="absolute bottom-0 left-0 w-96 h-96 bg-orange/5 rounded-full blur-3xl pointer-events-none -ml-48 -mb-48"
  >
  </div>

  <div class="max-w-6xl mx-auto px-5 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">
      <!-- Brand & Info -->
      <div class="md:col-span-2">
        <div class="flex items-center gap-4 mb-6">
          <img
            src="/logo.webp"
            alt="Stefano Moretti Logo"
            class="w-12 h-12 rounded-2xl shadow-2xl border border-white/10"
          />
          <div>
            <div
              class="text-white font-black text-lg tracking-tight leading-tight"
            >
              Ti aiuto con le bollette
            </div>
            <div
              class="text-orange text-[10px] font-black uppercase tracking-[0.2em]"
            >
              Consulenza Energetica
            </div>
          </div>
        </div>
        <p
          class="text-white/40 text-sm font-light leading-relaxed max-w-sm mb-8"
        >
          Consulenza energetica professionale e trasparente a Empoli e
          Provincia. Aiutiamo famiglie e imprese a ottimizzare i costi senza
          sprechi.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3
          class="text-white text-xs font-black uppercase tracking-widest mb-6"
        >
          Navigazione
        </h3>
        <nav class="flex flex-col gap-4">
          <a
            href="#chi-sono"
            class="text-white/40 hover:text-orange text-sm transition-all duration-300 w-fit"
            >Chi sono</a
          >
          <a
            href="#servizi"
            class="text-white/40 hover:text-orange text-sm transition-all duration-300 w-fit"
            >Servizi</a
          >
          <a
            href="#perche"
            class="text-white/40 hover:text-orange text-sm transition-all duration-300 w-fit"
            >Perché sceglierci</a
          >
          <a
            href="#contatti"
            class="text-white/40 hover:text-orange text-sm transition-all duration-300 w-fit"
            >Contatti</a
          >
        </nav>
      </div>

      <!-- Contact Info -->
      <div>
        <h3
          class="text-white text-xs font-black uppercase tracking-widest mb-6"
        >
          Contatti Rapidi
        </h3>
        <div class="flex flex-col gap-4">
          <a
            href="https://wa.me/393452409991"
            target="_blank"
            class="flex items-center gap-3 text-white/40 hover:text-[#25D366] transition-all duration-300 group"
          >
            <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current"
              ><path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
              ></path>
            </svg>
            <span class="text-sm">WhatsApp</span>
          </a>
          <a
            href="mailto:tiaiutoconlebollette@gmail.com"
            class="flex items-center gap-3 text-white/40 hover:text-white transition-all duration-300"
          >
            <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current"
              ><path
                d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"
              ></path>
            </svg>
            <span class="text-sm">Scrivici un'Email</span>
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div
      class="pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-6"
    >
      <div
        class="flex flex-wrap justify-center md:justify-start gap-x-6 gap-y-2 text-[10px] text-white/20 uppercase tracking-widest font-bold"
      >
        <span>P.IVA 06957050484</span>
        <span class="hidden md:inline">·</span>
        <span>Ruolo Agenti (REA): FI-648680</span>
        <span class="hidden md:inline">·</span>
        <span>Empoli e Provincia, Toscana</span>
      </div>

      <div
        class="flex gap-6 text-[10px] text-white/20 uppercase tracking-widest font-bold items-center"
      >
        <a href="/privacy" class="hover:text-white transition-colors">Privacy</a
        >
        <a href="/cookie" class="hover:text-white transition-colors">Cookies</a>
        <span>·</span>
        <p>© {new Date().getFullYear()} Ti aiuto con le bollette</p>
      </div>
    </div>

    <div class="mt-8 text-center">
      <p class="text-white/10 text-[9px] uppercase tracking-[0.3em]">
        Realizzato con ♥ in Toscana
      </p>
    </div>
  </div>
</footer>

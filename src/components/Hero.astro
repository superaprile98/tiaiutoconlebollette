---
---
  <section class="bg-cream pt-24 pb-0 overflow-hidden">
    <div class="max-w-6xl mx-auto px-5 grid md:grid-cols-2 gap-8 items-end">
      <!-- Left -->
      <div class="py-10 md:py-16">
        <div
          class="au inline-flex items-center gap-2 bg-orange-light text-orange text-xs font-semibold uppercase tracking-widest px-3 py-1.5 rounded-full mb-6">
          <span class="w-1.5 h-1.5 bg-orange rounded-full pulse"></span>
          Empolese Valdelsa · Toscana
        </div>
        <h1 class="au1 text-4xl md:text-5xl font-extrabold text-gray-900 leading-tight tracking-tight mb-5">
          Paghi troppo<br>per <span class="text-blue">luce e gas?</span><br>
          <span class="text-orange">Lo risolviamo.</span>
        </h1>
        <p class="au2 text-base md:text-lg text-gray-500 font-light leading-relaxed mb-8 max-w-md">
          Analizzo gratuitamente i tuoi contratti, trovo il fornitore più conveniente e gestisco tutta la burocrazia.
          <strong class="text-gray-700 font-semibold">Tu non fai nulla.</strong>
        </p>
        <div class="au3 flex flex-wrap gap-3 mb-10">
          <a href="#contatti"
            class="bg-orange hover:bg-orange-dark text-white font-bold px-6 py-3.5 rounded-full text-sm transition-all hover:-translate-y-0.5 shadow-sm hover:shadow-md">
            Richiedi consulenza gratuita →
          </a>
          <a href="#servizi"
            class="border border-gray-200 text-gray-700 hover:border-blue hover:text-blue font-medium px-6 py-3.5 rounded-full text-sm transition-colors">
            Come funziona
          </a>
        </div>
        <!-- Numeri -->
        <div class="au3 flex gap-8 pt-6 border-t border-gray-200">
          <div>
            <div class="text-2xl font-extrabold text-orange">100%</div>
            <div class="text-xs text-gray-400 mt-0.5">Gratuito per te</div>
          </div>
          <div>
            <div class="text-2xl font-extrabold text-blue">–20%</div>
            <div class="text-xs text-gray-400 mt-0.5">Risparmio medio</div>
          </div>
          <div>
            <div class="text-2xl font-extrabold text-green">14gg</div>
            <div class="text-xs text-gray-400 mt-0.5">Diritto di recesso</div>
          </div>
        </div>
      </div>
      <!-- Right: foto -->
      <div class="relative flex justify-center md:justify-end items-end h-full pt-8 md:pt-0">
        <!-- Badge Google flottante -->
        <div
          class="absolute top-8 right-0 md:right-4 bg-white rounded-2xl shadow-lg px-4 py-3 flex items-center gap-2 z-10">
          <div class="text-yellow-400 text-sm">★★★★★</div>
          <div>
            <div class="text-xs font-bold text-gray-800">Recensioni Google</div>
            <div class="text-xs text-gray-400">5.0 · Empolese Valdelsa</div>
          </div>
        </div>
        <!-- Card "come funziona" flottante -->
        <div
          class="absolute bottom-12 left-0 md:-left-4 bg-white rounded-2xl shadow-lg p-4 z-10 max-w-xs hidden md:block">
          <div class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">Come funziona</div>
          <div class="flex flex-col gap-2">
            <div class="flex items-center gap-2"><span
                class="w-6 h-6 bg-blue-light text-blue text-xs font-bold rounded-lg flex items-center justify-center flex-shrink-0">1</span><span
                class="text-xs text-gray-700 font-medium">Mandi la bolletta</span></div>
            <div class="flex items-center gap-2"><span
                class="w-6 h-6 bg-orange-light text-orange text-xs font-bold rounded-lg flex items-center justify-center flex-shrink-0">2</span><span
                class="text-xs text-gray-700 font-medium">Trovo le offerte migliori</span></div>
            <div class="flex items-center gap-2"><span
                class="w-6 h-6 bg-green-light text-green text-xs font-bold rounded-lg flex items-center justify-center flex-shrink-0">3</span><span
                class="text-xs text-gray-700 font-medium">Gestisco tutto io</span></div>
          </div>
        </div>
        <img src="https://images.unsplash.com/photo-1560250097-0b93528c311a?w=600&q=80"
          alt="Stefano Moretti – Consulente Energia" class="w-72 md:w-80 lg:w-96 object-cover object-top rounded-t-3xl"
          style="max-height:480px" />
      </div>
    </div>
  </section>

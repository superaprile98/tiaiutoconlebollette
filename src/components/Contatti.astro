---
---
  <section id="contatti" class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-5">
      <div class="fade text-center mb-12">
        <div
          class="inline-block bg-orange-light text-orange text-xs font-semibold uppercase tracking-widest px-3 py-1.5 rounded-full mb-4">
          Contatti</div>
        <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-3">Parliamoci.</h2>
        <p class="text-gray-400 font-light max-w-md mx-auto text-sm">Compila il modulo o scrivimi. Ti rispondo entro 24
          ore. Gratuito e senza impegno.</p>
      </div>
      <div
        class="fade d1 max-w-4xl mx-auto grid md:grid-cols-5 rounded-3xl overflow-hidden border border-gray-100 shadow-sm">
        <!-- Aside -->
        <div class="md:col-span-2 bg-blue p-8 flex flex-col gap-6">
          <div>
            <div class="font-bold text-white text-lg">Stefano Moretti</div>
            <div class="text-white/50 text-xs mt-1 font-light">Agente di commercio · Consulente energia</div>
          </div>
          <div class="flex flex-col gap-4">
            <div class="flex gap-3 items-start">
              <div class="w-8 h-8 bg-white/10 rounded-lg flex items-center justify-center text-sm flex-shrink-0">📍
              </div>
              <div>
                <div class="text-white text-sm font-medium">Zona operativa</div>
                <div class="text-white/40 text-xs">Empolese Valdelsa · Toscana</div>
              </div>
            </div>
            <div class="flex gap-3 items-start">
              <div class="w-8 h-8 bg-white/10 rounded-lg flex items-center justify-center text-sm flex-shrink-0">📞
              </div>
              <div>
                <div class="text-white text-sm font-medium">Telefono</div>
                <div class="text-white/40 text-xs">Da aggiungere</div>
              </div>
            </div>
            <div class="flex gap-3 items-start">
              <div class="w-8 h-8 bg-white/10 rounded-lg flex items-center justify-center text-sm flex-shrink-0">✉️
              </div>
              <div>
                <div class="text-white text-sm font-medium">Email</div>
                <div class="text-white/40 text-xs">Da aggiungere</div>
              </div>
            </div>
            <div class="flex gap-3 items-start">
              <div class="w-8 h-8 bg-white/10 rounded-lg flex items-center justify-center text-sm flex-shrink-0">🕐
              </div>
              <div>
                <div class="text-white text-sm font-medium">Orari</div>
                <div class="text-white/40 text-xs">Lun–Ven 9:00–18:00</div>
              </div>
            </div>
          </div>
          <div class="mt-auto text-white/20 text-xs leading-relaxed">
            P.IVA: da aggiungere<br>Reg. Agenti: da aggiungere<br>© 2025 Stefano Moretti
          </div>
        </div>
        <!-- Form -->
        <div class="md:col-span-3 bg-cream p-8">
          <div id="form-ok" class="hidden text-center py-10">
            <div class="text-4xl mb-3">✅</div>
            <h4 class="font-bold text-gray-900 text-lg mb-1">Messaggio inviato!</h4>
            <p class="text-gray-400 text-sm">Ti contatterò entro 24 ore.</p>
          </div>
          <form id="cform" class="flex flex-col gap-4">
            <div class="grid grid-cols-2 gap-3">
              <div class="flex flex-col gap-1">
                <label class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Nome *</label>
                <input type="text" name="user_name" placeholder="Mario" required
                  class="bg-white border border-gray-200 rounded-xl px-4 py-3 text-sm text-gray-800 outline-none focus:border-blue focus:ring-2 focus:ring-blue/10 transition" />
              </div>
              <div class="flex flex-col gap-1">
                <label class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Cognome *</label>
                <input type="text" name="user_surname" placeholder="Rossi" required
                  class="bg-white border border-gray-200 rounded-xl px-4 py-3 text-sm text-gray-800 outline-none focus:border-blue focus:ring-2 focus:ring-blue/10 transition" />
              </div>
            </div>
            <div class="flex flex-col gap-1">
              <label class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Telefono *</label>
              <input type="tel" name="user_phone" placeholder="333 000 0000" required
                class="bg-white border border-gray-200 rounded-xl px-4 py-3 text-sm text-gray-800 outline-none focus:border-blue focus:ring-2 focus:ring-blue/10 transition" />
            </div>
            <div class="flex flex-col gap-1">
              <label class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Tipo di richiesta</label>
              <select name="user_request_type"
                class="bg-white border border-gray-200 rounded-xl px-4 py-3 text-sm text-gray-800 outline-none focus:border-blue focus:ring-2 focus:ring-blue/10 transition">
                <option value="">Seleziona...</option>
                <option value="Analisi bolletta luce">Analisi bolletta luce</option>
                <option value="Analisi bolletta gas">Analisi bolletta gas</option>
                <option value="Cambio fornitore">Cambio fornitore</option>
                <option value="Consulenza azienda / negozio">Consulenza azienda / negozio</option>
                <option value="Altro">Altro</option>
              </select>
            </div>
            <div class="flex flex-col gap-1">
              <label class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Messaggio</label>
              <textarea name="user_message" placeholder="Raccontami la tua situazione..." rows="3"
                class="bg-white border border-gray-200 rounded-xl px-4 py-3 text-sm text-gray-800 outline-none focus:border-blue focus:ring-2 focus:ring-blue/10 transition resize-none"></textarea>
            </div>
            <div class="flex gap-2 items-start">
              <input type="checkbox" id="priv" required class="mt-0.5 flex-shrink-0 accent-blue" />
              <label for="priv" class="text-xs text-gray-400 leading-relaxed">Ho letto e accetto la <a href="#privacy"
                  class="text-blue">Privacy Policy</a>. Acconsento al trattamento dei miei dati ai sensi del GDPR (Reg.
                UE 2016/679).</label>
            </div>
            <!-- Feedback caricamento -->
            <div id="form-error" class="hidden text-red-500 text-sm font-semibold">Si è verificato un errore. Riprova più tardi.</div>
            
            <button type="submit" id="submit-btn"
              class="bg-orange hover:bg-orange-dark text-white font-bold py-3.5 rounded-xl text-sm transition-all hover:-translate-y-0.5 hover:shadow-md flex items-center justify-center gap-2">
              <span id="submit-text">Invia richiesta gratuita →</span>
              <span id="submit-spinner" class="hidden w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin"></span>
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

<script>
  import emailjs from '@emailjs/browser';

  // Utilizzo delle variabili d'ambiente per EmailJS
  const EMAILJS_SERVICE_ID = import.meta.env.PUBLIC_EMAILJS_SERVICE_ID;
  const EMAILJS_TEMPLATE_ID = import.meta.env.PUBLIC_EMAILJS_TEMPLATE_ID;
  const EMAILJS_PUBLIC_KEY = import.meta.env.PUBLIC_EMAILJS_PUBLIC_KEY;

  const cform = document.getElementById('cform') as HTMLFormElement;
  const formOk = document.getElementById('form-ok');
  const formError = document.getElementById('form-error');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const submitText = document.getElementById('submit-text');
  const submitSpinner = document.getElementById('submit-spinner');
  
  if (cform) {
    cform.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      if (!cform.checkValidity()) return;

      if(!EMAILJS_SERVICE_ID || !EMAILJS_TEMPLATE_ID || !EMAILJS_PUBLIC_KEY){
          alert("ATTENZIONE: Devi configurare i parametri di EmailJS nel pannello delle variabili d'ambiente (Environment Variables) o nel file .env!");
          return;
      }
      
      // Stato di caricamento
      if (submitBtn && submitText && submitSpinner) {
        submitBtn.disabled = true;
        submitBtn.classList.add('opacity-70', 'cursor-not-allowed');
        submitText.textContent = 'Invio in corso...';
        submitSpinner.classList.remove('hidden');
      }
      if (formError) formError.classList.add('hidden');

      try {
        await emailjs.sendForm(
          EMAILJS_SERVICE_ID,
          EMAILJS_TEMPLATE_ID,
          cform,
          EMAILJS_PUBLIC_KEY
        );
        
        // Successo
        cform.style.display = 'none';
        if (formOk) formOk.classList.remove('hidden');
      } catch (error) {
        console.error('Errore invio email:', error);
        // Errore
        if (formError) formError.classList.remove('hidden');
      } finally {
        // Ripristino stato bottone
        if (submitBtn && submitText && submitSpinner) {
          submitBtn.disabled = false;
          submitBtn.classList.remove('opacity-70', 'cursor-not-allowed');
          submitText.textContent = 'Invia richiesta gratuita →';
          submitSpinner.classList.add('hidden');
        }
      }
    });
  }
</script>

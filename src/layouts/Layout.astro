---
import "../styles/global.css";
import CookieBanner from "../components/CookieBanner.astro";


interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta
      name="description"
      content="Consulenza energetica gratuita a Empoli e Provincia. Analizziamo la tua bolletta luce e gas e troviamo il fornitore migliore per te. Prenota la tua consulenza gratuita."
    />

    <!-- Open Graph / Facebook / WhatsApp -->
    <meta
      property="og:url"
      content={`https://www.tiaiutoconlebollette.it${Astro.url.pathname}`}
    />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Ti aiuto con le bollette" />
    <meta property="og:title" content={title} />
    <meta
      property="og:description"
      content="Consulenza energetica professionale e trasparente a Empoli e Provincia. Diamo un volto umano alla tua bolletta."
    />
    <meta
      property="og:image"
      content="https://www.tiaiutoconlebollette.it/logo.webp"
    />
    <meta property="og:image:width" content="800" />
    <meta property="og:image:height" content="800" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap"
      />
    </noscript>
    <link
      rel="canonical"
      href={`https://www.tiaiutoconlebollette.it${Astro.url.pathname}`}
    />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "WebSite",
            "@id": "https://www.tiaiutoconlebollette.it/#website",
            url: "https://www.tiaiutoconlebollette.it/",
            name: "Ti aiuto con le bollette",
            inLanguage: "it-IT",
          },
          {
            "@type": ["LocalBusiness", "ProfessionalService"],
            name: "Ti aiuto con le bollette | Consulenza Luce e Gas",
            image: "https://www.tiaiutoconlebollette.it/logo.webp",
            url: "https://www.tiaiutoconlebollette.it",
            telephone: "+393452409991",
            email: "tiaiutoconlebollette@gmail.com",
            address: {
              "@type": "PostalAddress",
              addressLocality: "Empoli",
              addressRegion: "FI",
              addressCountry: "IT",
            },
            geo: {
              "@type": "GeoCoordinates",
              latitude: 43.717,
              longitude: 10.942,
            },
            serviceArea: {
              "@type": "GeoCircle",
              geoMidpoint: {
                "@type": "GeoCoordinates",
                latitude: 43.717,
                longitude: 10.942,
              },
              geoRadius: "50000",
            },
            description:
              "Consulenza energetica per ottimizzare e risparmiare sulle bollette di luce e gas. Analisi contratti mercato libero e revisione costi per privati e aziende (P.IVA) a Empoli, Firenze e Toscana.",
            openingHoursSpecification: {
              "@type": "OpeningHoursSpecification",
              dayOfWeek: [
                "Monday",
                "Tuesday",
                "Wednesday",
                "Thursday",
                "Friday",
              ],
              opens: "09:00",
              closes: "18:00",
            },
            priceRange: "€",
            areaServed: [
              "Empoli",
              "Firenze",
              "Prato",
              "Pistoia",
              "Certaldo",
              "Castelfiorentino",
              "Montelupo Fiorentino",
              "Vinci",
              "San Miniato",
              "Fucecchio",
              "Cerreto Guidi",
              "Capraia e Limite",
              "Signa",
              "Lastra a Signa",
              "Scandicci",
              "Pontedera",
              "Santa Croce sull'Arno",
              "Montopoli in Val d'Arno",
              "San Casciano in Val di Pesa",
              "Montespertoli",
              "Tavarnelle Val di Pesa",
              "Poggibonsi",
              "Colle di Val d'Elsa",
            ],
            knowsAbout: [
              "Consulenza energetica",
              "Risparmio bollette luce e gas",
              "Analisi mercato libero",
              "Ottimizzazione costi aziendali",
            ],
          },
        ],
      })}
    ></script>

    <!-- Google tag (gtag.js) -->
    <script
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-CCHVPRWYFD"
      is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }

      // Default consent state
      const consent = localStorage.getItem("cookie-consent");
      gtag("consent", "default", {
        ad_storage: consent === "granted" ? "granted" : "denied",
        analytics_storage: consent === "granted" ? "granted" : "denied",
        ad_user_data: consent === "granted" ? "granted" : "denied",
        ad_personalization: consent === "granted" ? "granted" : "denied",
      });

      gtag("js", new Date());
      gtag("config", "G-CCHVPRWYFD");
    </script>
  </head>

  <body class="bg-white font-sans text-gray-800 overflow-x-hidden">
    <slot />
    <CookieBanner />


    <script>
      // Scroll reveal with IntersectionObserver
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("in");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1 },
      );

      document.querySelectorAll(".fade").forEach((el) => {
        observer.observe(el);
      });
    </script>
  </body>
</html>

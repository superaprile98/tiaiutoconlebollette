---
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta
      name="description"
      content="Diamo un volto umano all'energia. Consulenza energetica trasparente e professionale a Empoli e Provincia con Stefano Moretti."
    />

    <!-- Open Graph / Facebook / WhatsApp -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta
      property="og:description"
      content="Consulenza energetica professionale e trasparente a Empoli e Provincia. Diamo un volto umano alla tua bolletta."
    />
    <meta property="og:image" content="/logo.webp" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link
      rel="canonical"
      href={`https://www.tiaiutoconlebollette.it${Astro.url.pathname}`}
    />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "Ti Aiuto Con Le Bollette",
        "image": "https://www.tiaiutoconlebollette.it/logo.webp",
        "url": "https://www.tiaiutoconlebollette.it",
        "telephone": "+393452409991",
        "email": "tiaiutoconlebollette@gmail.com",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Empoli e Provincia",
          "addressLocality": "Empoli",
          "addressRegion": "FI",
          "postalCode": "50053",
          "addressCountry": "IT"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": 43.717,
          "longitude": 10.942
        },
        "description": "Consulenza energetica professionale e trasparente a Empoli e Provincia con Stefano Moretti.",
        "openingHoursSpecification": {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
          "opens": "09:00",
          "closes": "18:00"
        },
        "priceRange": "$"
      }
    </script>
  </head>
  <body class="bg-white font-sans text-gray-800 overflow-x-hidden">
    <slot />

    <script>
      // Scroll reveal with IntersectionObserver
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("in");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1 },
      );

      document.querySelectorAll(".fade").forEach((el) => {
        observer.observe(el);
      });
    </script>
  </body>
</html>
